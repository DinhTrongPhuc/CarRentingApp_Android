<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent" android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:title="Thanh toán"
        app:titleTextColor="@color/white"
        app:navigationIconTint="@color/white"/>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Chọn phương thức thanh toán"
                android:textStyle="bold" android:textSize="18sp"
                android:layout_marginBottom="16dp"/>

            <!-- Payment Methods -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp" app:cardElevation="4dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">

                    <RadioButton android:id="@+id/rb_momo"
                        android:layout_width="match_parent" android:layout_height="56dp"
                        android:text="💜 Ví MoMo" android:textSize="16sp"
                        android:checked="true" android:layout_marginBottom="8dp"
                        android:buttonTint="@color/primary"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider"/>

                    <RadioButton android:id="@+id/rb_zalo_pay"
                        android:layout_width="match_parent" android:layout_height="56dp"
                        android:text="🔵 ZaloPay" android:textSize="16sp"
                        android:layout_marginBottom="8dp" android:layout_marginTop="8dp"
                        android:buttonTint="@color/primary"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider"/>

                    <RadioButton android:id="@+id/rb_bank"
                        android:layout_width="match_parent" android:layout_height="56dp"
                        android:text="🏦 Thẻ ngân hàng" android:textSize="16sp"
                        android:layout_marginTop="8dp"
                        android:buttonTint="@color/primary"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView android:id="@+id/tv_processing"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Đang xử lý thanh toán..." android:textColor="@color/primary"
                android:layout_gravity="center" android:visibility="gone"
                android:layout_marginBottom="8dp"/>

            <ProgressBar android:id="@+id/progress_bar"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="center" android:visibility="gone"
                android:layout_marginBottom="8dp"/>

            <!-- Success View -->
            <LinearLayout android:id="@+id/layout_success"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:gravity="center"
                android:padding="32dp" android:visibility="gone">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="✅" android:textSize="64sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Đặt xe thành công!" android:textSize="22sp"
                    android:textStyle="bold" android:textColor="@color/success"
                    android:layout_marginTop="16dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Chủ xe sẽ liên hệ xác nhận sớm nhất"
                    android:textColor="@color/text_secondary" android:layout_marginTop="8dp"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_done"
                    android:layout_width="match_parent" android:layout_height="56dp"
                    android:text="VỀ TRANG CHỦ" android:layout_marginTop="24dp"/>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_confirm_payment"
                android:layout_width="match_parent" android:layout_height="56dp"
                android:text="XÁC NHẬN THANH TOÁN" android:textSize="15sp"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
