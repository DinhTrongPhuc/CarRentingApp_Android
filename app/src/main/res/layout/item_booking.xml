<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_margin="6dp" app:cardCornerRadius="10dp" app:cardElevation="3dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="12dp">

        <ImageView android:id="@+id/iv_car"
            android:layout_width="72dp" android:layout_height="72dp"
            android:scaleType="centerCrop" android:src="@drawable/ic_car_placeholder"/>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:id="@+id/tv_car_name"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Tên xe"
                    android:textStyle="bold" android:textSize="15sp" android:maxLines="1"
                    android:ellipsize="end"/>
                <TextView android:id="@+id/tv_status"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Chờ xác nhận" android:textSize="11sp"
                    android:textStyle="bold"/>
            </LinearLayout>
            <TextView android:id="@+id/tv_dates"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="01/01/2025 - 05/01/2025" android:textColor="@color/text_secondary"
                android:textSize="12sp" android:layout_marginTop="4dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginTop="4dp">
                <TextView android:id="@+id/tv_days"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="5 ngày"
                    android:textColor="@color/gray" android:textSize="12sp"/>
                <TextView android:id="@+id/tv_total"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="2.500.000 VNĐ" android:textColor="@color/price_color"
                    android:textStyle="bold" android:textSize="13sp"/>
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_view_handover"
            style="@style/Widget.MaterialComponents.Button.TextButton.Icon"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:text="Biên bản"
            app:icon="@drawable/ic_document"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>